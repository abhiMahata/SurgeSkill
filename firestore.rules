rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAuth() {
      return request.auth != null;
    }
    
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function userRole() {
      return getUserDoc().data.role;
    }
    
    function userCollegeId() {
      return getUserDoc().data.collegeId;
    }
    
    function isCollegeAdmin(collegeId) {
      return userRole() == 'COLLEGE_ADMIN' && userCollegeId() == collegeId;
    }
    
    function isSuperAdmin() {
      return userRole() == 'SUPER_ADMIN';
    }
    
    function isSelf(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function getCommunityCollegeId(communityId) {
      return get(/databases/$(database)/documents/communities/$(communityId)).data.collegeId;
    }

    function isActiveMember(communityId, userId) {
      return get(/databases/$(database)/documents/communities/$(communityId)/members/$(userId)).data.status == 'ACTIVE';
    }
    
    function getCollegeDomain(collegeId) {
      return get(/databases/$(database)/documents/collegeDomains/$(collegeId)).data.domain;
    }

    function isFriend(pairId) {
      return exists(/databases/$(database)/documents/friendships/$(pairId));
    }

    function isNotBlocked(pairId) {
      return !exists(/databases/$(database)/documents/blocks/$(pairId));
    }

    function isEmailValidForCollege(collegeId) {
      // In Firestore Rules, string matching with regex:
      // Ensure token email matches anything + @ + the domain exactly at the end
      return request.auth.token.email.matches('.*@' + getCollegeDomain(collegeId) + '$');
    }

    function isModifyingProtectedUserFields() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return (affected.hasAny(['role']) && 'role' in resource.data) ||
             (affected.hasAny(['collegeId']) && 'collegeId' in resource.data) ||
             (affected.hasAny(['status']) && 'status' in resource.data) ||
             (affected.hasAny(['friendCode']) && 'friendCode' in resource.data) ||
             (affected.hasAny(['createdAt']) && 'createdAt' in resource.data) ||
             (affected.hasAny(['id']) && 'id' in resource.data) ||
             (affected.hasAny(['email']) && 'email' in resource.data);
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // ── College Domains ──────────────────────────────────────────────────────
    match /collegeDomains/{collegeId} {
      allow read: if isAuth();
    }

    // ── Friend Codes ─────────────────────────────────────────────────────────
    match /friendCodes/{code} {
      allow read: if isAuth();
      // Only allow creation if it doesn't exist, preventing overwrite
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── Users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isAuth();
      
      // Creation MUST be exactly a STUDENT and PENDING_ONBOARDING or ACTIVE, and email MUST match the domain.
      allow create: if isSelf(userId) &&
                       request.resource.data.role == 'STUDENT' &&
                       request.resource.data.status in ['PENDING_ONBOARDING', 'ACTIVE'] &&
                       isEmailValidForCollege(request.resource.data.collegeId);
                       
      // Updates cannot modify protected fields IF they already exist, UNLESS it's an admin.
      // If collegeId is being newly initialized (legacy migration), validate it.
      allow update: if (isSelf(userId) && 
                        !isModifyingProtectedUserFields() &&
                        (!('collegeId' in resource.data) && 'collegeId' in request.resource.data ? isEmailValidForCollege(request.resource.data.collegeId) : true)) ||
                       (isSuperAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'status', 'updatedAt'])) ||
                       (isCollegeAdmin(resource.data.collegeId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
      allow delete: if false; 
    }

    // ── Admin Logs ───────────────────────────────────────────────────────────
    match /adminLogs/{logId} {
      allow read: if isAuth() && (isSuperAdmin() || isCollegeAdmin(resource.data.collegeId));
      allow create: if isAuth() && (isSuperAdmin() || isCollegeAdmin(request.resource.data.collegeId)) && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Events ──────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth() && isCollegeAdmin(resource.data.collegeId);
    }

    // ── Communities ──────────────────────────────────────────────────────────
    match /communities/{communityId} {
      allow read: if isAuth() && userCollegeId() == resource.data.collegeId;
      allow create: if isAuth() && userCollegeId() == request.resource.data.collegeId;
      allow update: if isAuth() && isCollegeAdmin(resource.data.collegeId);
      allow delete: if isAuth() && isSuperAdmin();

      match /members/{userId} {
        allow read: if isAuth() && userCollegeId() == getCommunityCollegeId(communityId);
        allow create: if isSelf(userId) && userCollegeId() == getCommunityCollegeId(communityId);
        allow update: if isAuth() && (
          isCollegeAdmin(getCommunityCollegeId(communityId)) ||
          (
            isSelf(userId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
            resource.data.status == 'ACTIVE' &&
            request.resource.data.status == 'INACTIVE'
          )
        );
      }

      match /messages/{messageId} {
        allow read: if isAuth() && userCollegeId() == getCommunityCollegeId(communityId);
        allow create: if isAuth() && 
          isActiveMember(communityId, request.auth.uid) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.communityId == communityId &&
          request.resource.data.collegeId == getCommunityCollegeId(communityId);
        allow update: if false;
        allow delete: if false;
      }

      match /posts/{postId} {
        allow read: if isAuth() && userCollegeId() == getCommunityCollegeId(communityId);
        allow create: if isAuth() && 
          isActiveMember(communityId, request.auth.uid) &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.communityId == communityId &&
          request.resource.data.collegeId == getCommunityCollegeId(communityId);
        allow update: if (isAuth() && isSelf(resource.data.authorId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content', 'attachments', 'updatedAt'])) ||
                         (isAuth() && isCollegeAdmin(resource.data.collegeId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
        allow delete: if isAuth() && (isSelf(resource.data.authorId) || isCollegeAdmin(resource.data.collegeId));
        
        match /comments/{commentId} {
          allow read: if isAuth() && userCollegeId() == getCommunityCollegeId(communityId);
          allow create: if isAuth() && 
            isActiveMember(communityId, request.auth.uid) &&
            request.resource.data.authorId == request.auth.uid;
          allow update: if (isAuth() && isSelf(resource.data.authorId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content', 'updatedAt'])) ||
                           (isAuth() && isCollegeAdmin(resource.data.collegeId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
          allow delete: if isAuth() && (isSelf(resource.data.authorId) || isCollegeAdmin(resource.data.collegeId));
        }

        match /likes/{userId} {
          allow read: if isAuth() && userCollegeId() == getCommunityCollegeId(communityId);
          allow create, delete: if isAuth() && 
            isActiveMember(communityId, request.auth.uid) && 
            request.auth.uid == userId;
        }
      }
    }

    // ── Collection Group Queries ─────────────────────────────────────────────
    match /{path=**}/posts/{postId} {
      allow read: if isAuth() && userCollegeId() == resource.data.collegeId;
    }

    // ── Community Read States ────────────────────────────────────────────────
    match /communityReadStates/{readStateId} {
      allow read: if isAuth() && isSelf(resource.data.userId);
      allow create: if isAuth() && isSelf(request.resource.data.userId);
      allow update: if isAuth() && isSelf(resource.data.userId) && isSelf(request.resource.data.userId);
    }

    // ── Notifications ────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isAuth() && isSelf(resource.data.recipientId);
      allow create: if isAuth() && 
        userCollegeId() == request.resource.data.collegeId &&
        isSelf(request.resource.data.actorId) &&
        request.resource.data.recipientId != request.resource.data.actorId;
      allow update: if isAuth() && isSelf(resource.data.recipientId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuth() && isSelf(resource.data.recipientId);
    }

    // ── Events ───────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isAuth() && userCollegeId() == resource.data.collegeId;
      allow create: if isAuth() && 
        userCollegeId() == request.resource.data.collegeId &&
        isSelf(request.resource.data.createdBy) &&
        (
          (request.resource.data.scope == 'COLLEGE' && isCollegeAdmin(request.resource.data.collegeId)) ||
          (request.resource.data.scope == 'COMMUNITY' && isActiveMember(request.resource.data.communityId, request.auth.uid))
        );
      allow update: if isAuth() && userCollegeId() == resource.data.collegeId && (
        isCollegeAdmin(resource.data.collegeId) || isSelf(resource.data.createdBy) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['registrationCount'])
      );
      allow delete: if isAuth() && (isCollegeAdmin(resource.data.collegeId) || isSelf(resource.data.createdBy));
    }

    // ── Event Registrations ──────────────────────────────────────────────────
    match /eventRegistrations/{regId} {
      allow read: if isAuth() && userCollegeId() == resource.data.collegeId;
      allow create: if isAuth() && 
        userCollegeId() == request.resource.data.collegeId &&
        isSelf(request.resource.data.userId) &&
        regId == request.resource.data.eventId + '_' + request.resource.data.userId;
      allow delete: if isAuth() && isSelf(resource.data.userId);
    }

    // ── Friend Requests ──────────────────────────────────────────────────────
    match /friendRequests/{pairId} {
      allow read: if isAuth() && (isSelf(resource.data.senderId) || isSelf(resource.data.receiverId));
      allow create: if isAuth() && 
                    isSelf(request.resource.data.senderId) && 
                    request.resource.data.senderId != request.resource.data.receiverId &&
                    !exists(/databases/$(database)/documents/blocks/$(pairId)) &&
                    !exists(/databases/$(database)/documents/friendships/$(pairId));
      allow update: if isAuth() && isSelf(resource.data.receiverId) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'respondedAt']);
      allow delete: if isAuth() && (isSelf(resource.data.senderId) || isSelf(resource.data.receiverId));
    }

    // ── Friendships ──────────────────────────────────────────────────────────
    match /friendships/{pairId} {
      allow read: if isAuth() && request.auth.uid in resource.data.userIds;
      // Allow creation by receiver of the friend request when accepting
      allow create: if isAuth() && request.auth.uid in request.resource.data.userIds;
      allow update: if isAuth() && request.auth.uid in resource.data.userIds;
      allow delete: if isAuth() && request.auth.uid in resource.data.userIds;
    }

    // ── Blocks ───────────────────────────────────────────────────────────────
    match /blocks/{pairId} {
      allow read: if isAuth() && request.auth.uid in resource.data.userIds;
      allow create: if isAuth() && request.auth.uid == request.resource.data.initiatedBy;
      allow update: if isAuth() && request.auth.uid == resource.data.initiatedBy;
      allow delete: if isAuth() && request.auth.uid == resource.data.initiatedBy;
    }

    // ── Conversations ────────────────────────────────────────────────────────
    match /conversations/{pairId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participantIds;
      allow create: if isAuth() && 
                    request.auth.uid in request.resource.data.participantIds &&
                    isFriend(pairId) && isNotBlocked(pairId);
      allow update: if isAuth() && 
                    request.auth.uid in resource.data.participantIds &&
                    isFriend(pairId) && isNotBlocked(pairId) &&
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['participantIds']);
                    
      match /messages/{messageId} {
        allow read: if isAuth() && 
                    request.auth.uid in get(/databases/$(database)/documents/conversations/$(pairId)).data.participantIds;
        allow create: if isAuth() && 
                      request.auth.uid in get(/databases/$(database)/documents/conversations/$(pairId)).data.participantIds &&
                      request.resource.data.senderId == request.auth.uid &&
                      isFriend(pairId) && isNotBlocked(pairId);
        allow update, delete: if false; // Immutable MVP
      }
    }
  }
}
